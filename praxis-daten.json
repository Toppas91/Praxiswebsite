      }
    ],
    "vorsorgeuntersuchungen": [
      {
        "id": "vorsorge-001",
        "titel": "Vorsorgeuntersuchungen U2–U11",
        "beschreibung": "Gesetzliche Früherkennungsuntersuchungen von der Geburt bis zum 10. Lebensjahr – Überprüfung von Wachstum, Entwicklung und Gesundheit in jeder Altersphase."
      },
      {
        "id": "vorsorge-002",
        "titel": "Jugendgesundheitsuntersuchungen J1 & J2",
        "beschreibung": "J1 (12–14 Jahre) und J2 (16–17 Jahre) zur umfassenden körperlichen und psychosozialen Gesundheitsbeurteilung im Jugendalter."
      },
      {
        "id": "vorsorge-003",
        "titel": "Kindergartenuntersuchung",
        "beschreibung": "Ärztliche Untersuchung zur Vorlage bei Kindergarten oder Kindertagesstätte – kompetente Einschätzung des Entwicklungsstands."
      },
      {
        "id": "vorsorge-004",
        "titel": "Einschulungsuntersuchung",
        "beschreibung": "Ärztliche Untersuchung und Attest zur Schulreife – Beurteilung der körperlichen und geistigen Entwicklung vor Schulbeginn."
      },
      {
        "id": "vorsorge-005",
        "titel": "Jugendarbeitsschutzuntersuchung",
        "beschreibung": "Pflichtuntersuchung für Jugendliche vor Aufnahme einer Berufstätigkeit gemäß Jugendarbeitsschutzgesetz (JArbSchG)."
      }
    ],
    "diagnostik": [
      {
        "id": "diag-001",
        "titel": "Sehtest PLUSOPTIX",
        "beschreibung": "Computergestützte Sehtestung mittels PLUSOPTIX-Photoscreener – geeignet ab dem 7. Lebensmonat. Ermöglicht frühzeitige Erkennung von Fehlsichtigkeiten und Augenfehlstellungen, noch bevor Kinder selbst Auskunft geben können."
      },
      {
        "id": "diag-002",
        "titel": "Seh- und Hörtest",
        "beschreibung": "Überprüfung von Sehvermögen und Hörfähigkeit – als fester Bestandteil der Vorsorgeuntersuchungen sowie bei konkretem Verdacht auf Beeinträchtigungen."
      },
      {
        "id": "diag-003",
        "titel": "Lungenfunktionsmessung",
        "beschreibung": "Spirometrie zur Beurteilung der Lungenfunktion und Atemwegskapazität, inkl. Bronchospasmolyse-Test bei Verdacht auf Asthma oder obstruktive Atemwegserkrankungen."
      },
      {
        "id": "diag-004",
        "titel": "Ultraschall-Diagnostik",
        "beschreibung": "Sonographie der Säuglingshüfte, des Abdomens, der Nieren und ableitenden Harnwege, des Schädels sowie der Halsweichteile."
      },
      {
        "id": "diag-005",
        "titel": "EKG",
        "beschreibung": "Elektrokardiogramm zur Beurteilung der Herzfunktion – bei kardiologischer Fragestellung, nach Synkopen sowie im Rahmen der prä- und postoperativen Betreuung."
      },
      {
        "id": "diag-006",
        "titel": "Allergiediagnostik",
        "beschreibung": "Epikutane Hauttestung, Prick-Test und RAST-Untersuchungen (spezifisches IgE im Blut) zur systematischen Abklärung von Nahrungsmittel- und Umweltallergien."
      },
      {
        "id": "diag-007",
        "titel": "Entwicklungsdiagnostik",
        "beschreibung": "Standardisierte Entwicklungstests (ET 6-6, ETS 4-8, Motoriktest, Denver-Test) zur differenzierten Beurteilung der motorischen, sprachlichen und kognitiven Entwicklung."
      },
      {
        "id": "diag-008",
        "titel": "Laboruntersuchungen & Schnelltests",
        "beschreibung": "Blutuntersuchungen, Urinanalyse, mikrobiologische Untersuchungen, Tuberkulose-Testung sowie Schnelltests für Streptokokken Gruppe A (Scharlach) und CRP (Infektionsparameter)."
      }
    ],
    "allgemeine_leistungen": [
